# Backend Environment Configuration
# Copy this file to .env and update with your values

# ===========================================
# DATABASE CONFIGURATION (Required)
# ===========================================

# MySQL Connection for async operations (FastAPI)
MYSQL_URL=mysql+aiomysql://buscare_user:YOUR_DB_PASSWORD@localhost/buscare

# MySQL Connection for sync operations (schema creation)
MYSQL_URL_SYNC=mysql+pymysql://buscare_user:YOUR_DB_PASSWORD@localhost/buscare

# Database credentials (for reference)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=buscare
DB_USER=buscare_user
DB_PASSWORD=YOUR_DB_PASSWORD

# ===========================================
# SERVER CONFIGURATION
# ===========================================
HOST=0.0.0.0
PORT=8001
DEBUG=false

# ===========================================
# CORS CONFIGURATION (Required)
# ===========================================
# Comma-separated list of allowed origins
# Development: http://localhost:3000
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000

# ===========================================
# JWT CONFIGURATION (Required)
# ===========================================
# Generate secure key: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
MAX_UPLOAD_SIZE=52428800
UPLOAD_PATH=./uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp3,mp4,wav,webm

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
